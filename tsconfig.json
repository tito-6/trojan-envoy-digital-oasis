{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    // ESM settings for Node
    "module": "NodeNext",
    "target": "ES2022",
    "moduleResolution": "NodeNext",

    // Common TypeScript settings
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Path aliases (example)
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
